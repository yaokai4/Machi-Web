      "listen_gist": 65,
      "listen_response": 95,
      "listen_integrated": 35
    }
  },
  "qtypes": {
    "kanji_reading": {"abbreviation": "kr", "section": "vocab", "groupMode": "single", "minimumGroupMembers": 0},
    "orthography": {"abbreviation": "or", "section": "vocab", "groupMode": "single", "minimumGroupMembers": 0},
    "word_formation": {"abbreviation": "wf", "section": "vocab", "groupMode": "single", "minimumGroupMembers": 0},
    "context": {"abbreviation": "cx", "section": "vocab", "groupMode": "single", "minimumGroupMembers": 0},
    "paraphrase": {"abbreviation": "pp", "section": "vocab", "groupMode": "single", "minimumGroupMembers": 0},
    "usage": {"abbreviation": "us", "section": "vocab", "groupMode": "single", "minimumGroupMembers": 0},
    "grammar_form": {"abbreviation": "gf", "section": "grammar", "groupMode": "single", "minimumGroupMembers": 0},
    "sentence_assembly": {"abbreviation": "sa", "section": "grammar", "groupMode": "single", "minimumGroupMembers": 0},
    "text_grammar": {"abbreviation": "tg", "section": "grammar", "groupMode": "atomic", "minimumGroupMembers": 2},
    "reading_short": {"abbreviation": "rs", "section": "reading", "groupMode": "atomic", "minimumGroupMembers": 1},
    "reading_mid": {"abbreviation": "rm", "section": "reading", "groupMode": "atomic", "minimumGroupMembers": 1},
    "reading_long": {"abbreviation": "rl", "section": "reading", "groupMode": "atomic", "minimumGroupMembers": 1},
    "reading_info": {"abbreviation": "ri", "section": "reading", "groupMode": "atomic", "minimumGroupMembers": 1},
    "listen_task": {"abbreviation": "lt", "section": "listening", "groupMode": "single_script", "minimumGroupMembers": 0},
    "listen_point": {"abbreviation": "lp", "section": "listening", "groupMode": "single_script", "minimumGroupMembers": 0},
    "listen_gist": {"abbreviation": "lg", "section": "listening", "groupMode": "single_script", "minimumGroupMembers": 0},
    "listen_response": {"abbreviation": "lr", "section": "listening", "groupMode": "single_script", "minimumGroupMembers": 0},
    "listen_integrated": {"abbreviation": "li", "section": "listening", "groupMode": "single_script", "minimumGroupMembers": 0}
  },
