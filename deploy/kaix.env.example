# /etc/kaix.env — production environment for KaiX
#
# Copy to /etc/kaix.env, fill in values, then:
#   chmod 600 /etc/kaix.env
#   chown root:root /etc/kaix.env
#
# Do NOT commit a populated copy of this file to git.

# Production flag — triggers stricter defaults, hides stack traces in
# 500 responses, disables demo data seeding, requires a real pepper.
KAIX_ENV=production

# 64+ random characters. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
KAIX_PASSWORD_PEPPER=REPLACE_WITH_A_64_CHAR_RANDOM_STRING

# Comma-separated origin allowlist. Anything not in this set is denied
# CORS access to /api/*. Set to your real domains in production.
KAIX_ALLOWED_ORIGINS=https://machicity.com,https://www.machicity.com

# Bind address — keep on 127.0.0.1 so only nginx can reach it.
KAIX_HOST=127.0.0.1
KAIX_PORT=8787

# Session lifetime, in days.
KAIX_SESSION_TTL_DAYS=30

# Optional. When set, only the /api/auth/register request that includes
# a matching `bootstrap_token` body field is promoted to admin. Leave
# unset for single-operator deploys where the first registered user
# should simply become admin (legacy behaviour).
#KAIX_ADMIN_BOOTSTRAP_TOKEN=

# Upload caps.
KAIX_MAX_UPLOAD_BYTES=52428800
KAIX_MAX_JSON_BYTES=262144

# Web-client → API rewrite target. For a single-host deploy this is the
# loopback backend; behind a CDN it's the public origin.
NEXT_PUBLIC_API_BASE=https://www.machicity.com
NEXT_PUBLIC_SITE_URL=https://www.machicity.com
