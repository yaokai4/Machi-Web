# Caddy edge for the Docker stack. Auto-HTTPS when MACHI_DOMAIN is a real
# domain pointed at this host; falls back to :80 for local testing.
#
#   MACHI_DOMAIN=www.machicity.com docker compose up -d
#   MACHI_DOMAIN=:80              docker compose up -d   # local / behind an LB
#
# Upstreams are Docker service names. `backend` is the scalable HTTP pool;
# the `dynamic a` upstream module re-resolves its replica IPs via Docker's
# embedded DNS (127.0.0.11) so newly scaled containers join the load balancer
# automatically. The singleton `scheduler` service is intentionally NOT here.

{
	# email for Let's Encrypt (override with ACME_EMAIL)
	email {$ACME_EMAIL:admin@machicity.com}
}

{$MACHI_DOMAIN:localhost} {
	encode zstd gzip

	header {
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	# Server-Sent Events: stream without buffering.
	handle /api/events {
		reverse_proxy {
			dynamic a {
				name backend
				port 8787
				refresh 5s
				resolvers 127.0.0.11
			}
			flush_interval -1
		}
	}

	# Uploaded media -> backend pool, long-cache immutable.
	handle /media/* {
		header Cache-Control "public, max-age=2592000, immutable"
		reverse_proxy {
			dynamic a {
				name backend
				port 8787
				refresh 5s
				resolvers 127.0.0.11
			}
			lb_policy least_conn
			fail_duration 10s
		}
	}

	# API + health -> backend pool.
	@backend path /api/* /healthz /readyz
	handle @backend {
		reverse_proxy {
			dynamic a {
				name backend
				port 8787
				refresh 5s
				resolvers 127.0.0.11
			}
			lb_policy least_conn
			fail_duration 10s
		}
	}

	# long-cache immutable Next assets
	handle /_next/static/* {
		header Cache-Control "public, max-age=31536000, immutable"
		reverse_proxy web:3000
	}

	# service worker must never be edge-cached
	handle /sw.js {
		header Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
		header Service-Worker-Allowed "/"
		reverse_proxy web:3000
	}

	# everything else -> Next.js
	handle {
		reverse_proxy web:3000
	}
}
