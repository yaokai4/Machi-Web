# Machi web (Next.js 15) — multi-stage: build, then a lean runtime.
#
# Build context is the repo's `web/` dir:
#   docker build -f deploy/docker/Dockerfile.web -t machi-web .
FROM node:20-slim AS build
WORKDIR /app
ENV NEXT_TELEMETRY_DISABLED=1

# Deps (cached unless package*.json changes).
COPY app/package.json app/package-lock.json* ./
RUN npm ci

# Source + production build (runs clean + next build + font-manifest fix).
COPY app/ ./
RUN npm run build

# ---- runtime ----
FROM node:20-slim AS run
WORKDIR /app
ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000
RUN useradd --create-home --uid 10002 web
USER web

# Ship only what `next start` needs.
COPY --from=build --chown=web /app/.next ./.next
COPY --from=build --chown=web /app/public ./public
COPY --from=build --chown=web /app/node_modules ./node_modules
COPY --from=build --chown=web /app/package.json ./package.json
COPY --from=build --chown=web /app/next.config.mjs ./next.config.mjs

EXPOSE 3000
CMD ["npm", "run", "start"]
