{
  "name": "machi-web",
  "version": "1.0.0",
  "private": true,
  "description": "Machi Web — city and country scoped local-life client sharing the same backend, accounts and database with the iOS app.",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "npm run clean && next build && node scripts/fix-next-font-manifest.mjs && node scripts/repair-next-server-chunks.mjs",
    "start": "next start -p 3000",
    "clean": "rm -rf .next types tsconfig.tsbuildinfo",
    "fresh-build": "npm run build && node scripts/check-build.mjs",
    "check-build": "node scripts/check-build.mjs",
    "doctor": "node scripts/doctor.mjs",
    "lint": "eslint . --max-warnings=0",
    "test:home:ssr": "node scripts/check-home-ssr.mjs",
    "type-check": "rm -rf .next/types tsconfig.tsbuildinfo && tsc --noEmit --incremental false",
    "typecheck": "npm run type-check",
    "seed:japan-news-demo": "python3 ../scripts/seed_japan_news_demo.py",
    "seed:japan-news-sources": "python3 ../scripts/seed_japan_news_sources.py"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.452.0",
    "next": "^15.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "simple-icons": "^16.23.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.18",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
