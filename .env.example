# Machi backend (server.py) — environment configuration EXAMPLE.
#
# Copy to `.env` and fill in real values for your deployment. This file is
# committed; the real `.env` is git-ignored. server.py does NOT auto-load a
# .env file — export these into the process environment, e.g.:
#
#     set -a && . ./.env && set +a && python3 server.py
#
# or supply them via systemd / Docker / your process manager.
#
# NEVER commit real secrets (peppers, SMTP/Resend keys, admin password).

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
# "development" or "production". Production rejects the dev pepper and enables
# HSTS; it also locks down CORS unless KAIX_ALLOWED_ORIGINS is set.
KAIX_ENV=production
KAIX_HOST=127.0.0.1
KAIX_PORT=8787
# Kernel accept backlog for short bursts of parallel mobile/Web requests.
KAIX_HTTP_REQUEST_QUEUE_SIZE=256
# Absolute path to the SQLite database. Keep it OUTSIDE the repo in prod so it
# is never committed. Defaults to <repo>/web/kaix.db when unset.
KAIX_DB_PATH=/var/lib/machi/kaix.db
# Comma-separated allowlist of browser origins. Empty in production = no
# cross-origin browser access. Example: https://machi.city,https://www.machi.city
KAIX_ALLOWED_ORIGINS=
KAIX_SESSION_TTL_DAYS=30
KAIX_MAX_UPLOAD_BYTES=52428800
KAIX_MAX_JSON_BYTES=262144

# ---------------------------------------------------------------------------
# Amazon S3 / CloudFront uploads
# ---------------------------------------------------------------------------
# Clients never receive AWS keys. On EC2, boto3 uses the AWS SDK default
# credential chain and the attached Instance Profile / IAM Role.
# In development, if boto3/default credentials are unavailable, /api/uploads
# uses a local fallback while preserving the same presign -> PUT -> complete flow.
AWS_REGION=ap-northeast-1
AWS_S3_BUCKET=machi-s3
AWS_CLOUDFRONT_DOMAIN=https://dog232f3wzni4.cloudfront.net
# 32 random bytes encoded as base64. Keep this stable: changing it makes
# existing private attachments and paid/member files unreadable.
# Generate once with: openssl rand -base64 32
KAIX_PRIVATE_MEDIA_KEY=replace-with-32-random-bytes-in-base64
S3_UPLOAD_MAX_SIZE=335544320
S3_PRESIGN_EXPIRES_SECONDS=300
S3_PRIVATE_DOWNLOAD_EXPIRES_SECONDS=600
# Optional absolute public API base for generated local fallback URLs.
KAIX_PUBLIC_BASE_URL=https://machicity.com

# ---------------------------------------------------------------------------
# Secrets — REQUIRED in production. Generate with: openssl rand -hex 32
# ---------------------------------------------------------------------------
# Used to derive password hashes (PBKDF2-HMAC-SHA256). Changing it invalidates
# ALL existing passwords, so set it ONCE and keep it stable + secret.
KAIX_PASSWORD_PEPPER=replace-with-a-long-random-secret
# Used to HMAC email verification codes. If unset, it is derived from the
# password pepper. Set explicitly to rotate code hashing independently.
KAIX_EMAIL_CODE_PEPPER=

# ---------------------------------------------------------------------------
# Default admin account
# ---------------------------------------------------------------------------
# The initial admin is auto-seeded on first boot if it doesn't exist. Existing
# admins are always preserved (never overwritten or demoted), and the password
# is never logged or returned by the API.
KAIX_ADMIN_HANDLE=admin
# Initial password — used ONLY to create the admin if it doesn't yet exist.
# There is NO built-in default: if this is unset, the admin is NOT auto-created
# (the server logs a warning). Set a strong value here, or seed later with
# `KAIX_ADMIN_INITIAL_PASSWORD=... python3 scripts/seed_admin.py`. Rotate after
# first login via POST /api/auth/change-password.
KAIX_ADMIN_INITIAL_PASSWORD=set-a-strong-initial-password
# Optional. Attach an email so the admin can use code-based login / reset.
# REQUIRED if you enable KAIX_LOGIN_REQUIRE_CODE (codes need an address).
KAIX_ADMIN_EMAIL=
KAIX_ADMIN_DISPLAY_NAME=Machi Admin
# Optional. When set, registration must present a matching `bootstrap_token`
# to be promoted to admin (closes the first-registration race). Leave empty
# for single-operator/dev installs.
KAIX_ADMIN_BOOTSTRAP_TOKEN=

# ---------------------------------------------------------------------------
# Email verification + 2-step login (feature gates default OFF)
# ---------------------------------------------------------------------------
# "1" forces a verified email + code at registration. When "0", the code path
# still activates opportunistically if the client submits a `code`.
KAIX_REQUIRE_EMAIL_VERIFICATION=0
# "1" closes single-step /api/auth/login and forces the /login/start +
# /login/verify (email-code) flow. Accounts must have an email on file.
KAIX_LOGIN_REQUIRE_CODE=0
KAIX_EMAIL_CODE_TTL_SEC=600
KAIX_EMAIL_CODE_MAX_ATTEMPTS=5
KAIX_EMAIL_CODE_RESEND_COOLDOWN_SEC=60

# ---------------------------------------------------------------------------
# Google account sign-in (OAuth 2.0)
# ---------------------------------------------------------------------------
# The backend owns the whole flow: it builds the consent URL, verifies the
# state, exchanges the code for a profile and issues the SAME Machi bearer
# session as password login. Web AND iOS share this single "Web application"
# OAuth client — the iOS app drives it through ASWebAuthenticationSession, so
# no separate native client secret is needed. NEVER expose CLIENT_SECRET to
# the frontend, app bundle, or logs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Leave blank to derive {scheme}://{host}/api/auth/google/callback from the
# request (honors X-Forwarded-Proto/Host behind a proxy). In production set it
# explicitly so it can't drift, and register the EXACT value in the Google
# Console under "Authorized redirect URIs":
#   GOOGLE_OAUTH_REDIRECT_URI=https://machicity.com/api/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=
# Custom-scheme deep link the iOS app listens on; the callback redirects here
# with the issued session token. Must stay in sync with the app's URL handling.
GOOGLE_IOS_CALLBACK_URL=machi://auth/google
GOOGLE_OAUTH_STATE_TTL_SEC=600

# ---------------------------------------------------------------------------
# Email transport
# ---------------------------------------------------------------------------
# "console_file" (dev: writes to the dev outbox), "smtp", or "resend".
KAIX_EMAIL_TRANSPORT=console_file
KAIX_EMAIL_FROM=Machi <no-reply@machi.city>
KAIX_EMAIL_REPLY_TO=
# Dev only: directory the console_file transport writes messages to.
KAIX_DEV_OUTBOX_DIR=
# SMTP (when KAIX_EMAIL_TRANSPORT=smtp)
KAIX_SMTP_HOST=
KAIX_SMTP_PORT=587
KAIX_SMTP_USERNAME=
KAIX_SMTP_PASSWORD=
KAIX_SMTP_USE_TLS=1
# Resend (when KAIX_EMAIL_TRANSPORT=resend)
KAIX_RESEND_API_KEY=

# ---------------------------------------------------------------------------
# Visitor analytics (access log)
# ---------------------------------------------------------------------------
KAIX_VISITOR_LOG_ENABLED=1
# Collapse repeated hits from the same client within this window (seconds).
KAIX_VISITOR_LOG_DEDUP_SEC=300
# Run scripts/cleanup_visitor_logs.py periodically to enforce this.
KAIX_VISITOR_LOG_RETENTION_DAYS=90
# GeoIP resolver for visitor region: "none", "ipapi" (external HTTP lookup),
# or "maxmind" (local DB; requires the geoip2 package + KAIX_GEOIP_MAXMIND_DB).
KAIX_GEOIP_TRANSPORT=none
KAIX_GEOIP_MAXMIND_DB=

# ---------------------------------------------------------------------------
# Machi Verified membership (¥18/月；¥198/年)
# ---------------------------------------------------------------------------
# The plan key is the canonical reference used by every client + provider.
MEMBERSHIP_PLAN_KEY=machi_verified_monthly
# Price in whole CNY. The server ALWAYS recomputes the charge from this —
# a client-supplied amount is never trusted.
MEMBERSHIP_PRICE_CNY=18
# Daily publish caps (membership perk: members get the higher ceiling).
# 0 = unlimited. Defaults below are high enough that ordinary users are
# never impeded in practice, while members get clear headroom + it doubles
# as light anti-spam. Tune freely.
MEMBERSHIP_DAILY_LIMIT_FREE=30
MEMBERSHIP_DAILY_LIMIT_VERIFIED=300
# Gentle hot-feed ranking nudge for verified members (keep it small).
MEMBERSHIP_VERIFIED_BOOST=1.05
# Apple App Store product id for the same plan (iOS buys via IAP).
APPLE_IAP_PRODUCT_ID=machi_yuedu_18
APPLE_IAP_PRODUCT_ID_YEARLY=machi_1niandu_198

# ---------------------------------------------------------------------------
# Payments — provider credentials (NEVER commit real values)
# ---------------------------------------------------------------------------
# Leave blank to run without a provider. With PAYMENT_MOCK_ENABLED=1 in a
# non-production env, a dev mock-settlement path is available so the Web
# flow can be exercised end-to-end before real merchant credentials exist.
# Mock settlement is HARD-disabled in production regardless of this flag.
PAYMENT_MOCK_ENABLED=0
# How long an unpaid order stays payable (seconds).
PAYMENT_ORDER_TTL_SEC=900

# WeChat Pay v3 (Native / QR). Real settlement needs the `cryptography`
# package + the merchant cert chain.
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_NOTIFY_URL=https://machicity.com/api/payments/webhook/wechat

# Alipay (page/wap pay). Real settlement needs the `cryptography` package.
# Keys are PEM bodies (with or without the BEGIN/END armor).
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_NOTIFY_URL=https://machicity.com/api/payments/webhook/alipay
ALIPAY_RETURN_URL=https://machicity.com/membership?paid=1

# Apple IAP / App Store Server API. The signed StoreKit2 transaction is
# verified server-side; production transactions require signature checks.
APPLE_IAP_BUNDLE_ID=com.yaokai.kaizi
APPLE_IAP_ISSUER_ID=
APPLE_IAP_KEY_ID=
APPLE_IAP_PRIVATE_KEY=
APPLE_IAP_PRIVATE_KEY_PATH=
APPLE_IAP_SHARED_SECRET=
APPLE_IAP_ENVIRONMENT=Production
# App Store Connect -> App Store 服务器通知 -> 生产环境服务器 URL:
APPLE_APP_STORE_NOTIFICATION_URL=https://machicity.com/api/payments/webhook/apple

# Stripe (overseas / card payments via hosted Checkout). Only the secret
# key + webhook signing secret are needed server-side; webhook verification
# is plain HMAC-SHA256 (no extra packages). The overseas price is charged
# in STRIPE_CURRENCY at STRIPE_PRICE_CENTS (independent of the CNY plan).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CENTS=199
STRIPE_CURRENCY=usd
STRIPE_SUCCESS_URL=https://machicity.com/membership?paid=1
STRIPE_CANCEL_URL=https://machicity.com/membership

# --- Sentry-lite 错误上报（可选）---
# 填入 Sentry 项目 DSN 后,所有 500/支付/迁移/后台任务错误自动上报;留空则完全关闭。
KAIX_SENTRY_DSN=

# --- 邮件错误摘要（可选,与 Sentry 可并存）---
# 设置收件邮箱后,ERROR 级日志按窗口聚合成一封摘要邮件（复用上面的 SMTP 配置,
# 防风暴:每窗口最多一封）。零外部账号依赖,生产建议至少开启此通道。
KAIX_ERROR_REPORT_EMAIL=
KAIX_ERROR_REPORT_WINDOW_SEC=600

# --- 登录图形验证码模式 ---
# 1=每次登录都要验证码(需所有客户端已带 UI); 0=登录不要验证码(旧包兼容);
# adaptive=同 IP/同账号 15 分钟内失败 ≥3 次才要求(推荐:旧包正常用户无感,
# 撞库机器人立刻被拦,新客户端的验证码行会按需自动出现)。
KAIX_CAPTCHA_LOGIN_ENABLED=adaptive
KAIX_CAPTCHA_LOGIN_FAIL_THRESHOLD=3
KAIX_CAPTCHA_LOGIN_FAIL_WINDOW_SEC=900

# --- APNs 远程推送（可选;前三项齐全即自动启用,缺任一项=完全关闭）---
# 注意:APNs 需要“专用推送密钥”,不能用 App Store Connect API 密钥!
# 必须在 developer.apple.com → Certificates, Identifiers & Profiles → Keys
# 新建一个勾选 “Apple Push Notifications service (APNs)” 的密钥,下载
# AuthKey_XXXXXXXX.p8。用 App Store Connect API 密钥会被 Apple 拒绝
# (403 InvalidProviderToken),推送静默失败。
# APNS_KEY_P8_PATH 指向该 AuthKey_XXXXXXXX.p8;
# 或用 APNS_KEY_P8 直接放 PEM 内容(systemd 单行 env 用 \n 转义换行)。
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_KEY_P8_PATH=
APNS_BUNDLE_ID=com.yaokai.kaizi
APNS_ENVIRONMENT=production
